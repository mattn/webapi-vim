Describe webapi#xml#parse
  It restores maxmempattern after successful parse
    let old = &maxmempattern
    call webapi#xml#parse('<root><child/></root>')
    Assert Equals(&maxmempattern, old)
  End

  It restores maxfuncdepth after successful parse
    let old = &maxfuncdepth
    call webapi#xml#parse('<root><child/></root>')
    Assert Equals(&maxfuncdepth, old)
  End

  It parses simple xml
    let node = webapi#xml#parse('<root><child/></root>')
    Assert Equals(node.name, 'root')
    Assert Equals(len(node.child), 1)
    Assert Equals(node.child[0].name, 'child')
  End

  It parses attributes
    let node = webapi#xml#parse('<root key="value"/>')
    Assert Equals(node.attr.key, 'value')
  End

  It parses text content
    let node = webapi#xml#parse('<root>hello</root>')
    Assert Equals(node.value(), 'hello')
  End
End
